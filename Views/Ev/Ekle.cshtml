@model TinyHouseReservations.Models.Ev

<h2>Yeni Ev Ekle</h2>

<form asp-action="Ekle" method="post" class="form">
    <div class="form-group">
        <label>Başlık</label>
        <input asp-for="Baslik" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Açıklama</label>
        <textarea asp-for="Aciklama" class="form-control" rows="3"></textarea>
    </div>
    <div class="form-group">
        <label>Konum</label>
        <input asp-for="Konum" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Fiyat</label>
        <input asp-for="Fiyat" type="number" step="0.01" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Durum</label>
        <select asp-for="Durum" class="form-control">
            <option value="true">Aktif</option>
            <option value="false">Pasif</option>
        </select>
    </div>
    <div class="form-group">
        <label>Görsel Yolu (isteğe bağlı)</label>
        <input asp-for="GorselYolu" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Kaydet</button>
</form>
